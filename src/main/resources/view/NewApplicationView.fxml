<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.NewApplicationController">
    <VBox spacing="16" maxWidth="600" alignment="TOP_CENTER">
        <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

        <Label text="New Application" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Company *"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="companyField"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Role *"     GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="roleField"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Status *"   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ChoiceBox fx:id="statusChoice" maxWidth="Infinity"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Pay ($/hr)" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="payField" promptText="Optional"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Location"   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="locationField" promptText="Optional"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        </GridPane>

        <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel"           onAction="#handleCancel"/>
            <Button text="Save Application" onAction="#handleSubmit"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;"/>
        </HBox>
    </VBox>
</ScrollPane>
